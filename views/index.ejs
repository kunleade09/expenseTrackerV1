<%- include('partials/header', { page: 'dashboard' }) %>

    <!-- TOP BAR -->
    <header class="topbar">
      <div>
        <h1 class="page-title">Dashboard</h1>
        <p class="page-sub">Track every naira you spend</p>
      </div>
      <button class="btn-set-budget" onclick="openBudgetModal()">＋ Set Budget</button>
    </header>

    <!-- STAT CARDS -->
    <section class="stats-row">

      <div class="stat-card stat-budget">
        <p class="stat-label">Monthly Budget</p>
        <p class="stat-amount">₦<%= budget.toLocaleString() %></p>
        <span class="stat-badge">This Month</span>
      </div>

      <div class="stat-card stat-spent">
        <p class="stat-label">Total Spent</p>
        <p class="stat-amount">₦<%= totalMoneySpent.toLocaleString() %></p>
        <span class="stat-badge"><%=expenseCount%> transactions</span>
      </div>

      <div class="stat-card stat-remaining">
        <p class="stat-label">Remaining</p>
        <p class="stat-amount">₦<%= remaining.toLocaleString() %></p>
        <span class="stat-badge"><%=spentPercent%>% used</span>
      </div>

    </section>

    <!-- PROGRESS BAR -->
    <section class="budget-progress-section">
      <div class="progress-header">
        <span>Budget Usage</span>
        <span class="progress-pct"><%=spentPercent%>%</span>
      </div>
      <div class="progress-track">
        <div class="progress-fill <%= progressClass %>" style="width: <%=spentPercent%>%%"></div>
      </div>
      <div class="progress-labels">
        <span>₦0</span>
        <span>₦<%=budget.toLocaleString()%></span>
      </div>
    </section>

    <!-- TWO-COLUMN SECTION -->
    <div class="lower-grid">

      <!-- ADD EXPENSE FORM -->
      <section class="card form-card">
        <h2 class="card-title">Add Expense</h2>
        <form action="/expenses" method="POST" class="expense-form">

          <div class="form-group">
            <label for="name">Description</label>
            <input type="text" id="name" name="name" placeholder="e.g. Grocery run" required />
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="amount">Amount (₦)</label>
              <input type="number" id="amount" name="amount" placeholder="0.00" min="1" required />
            </div>
            <div class="form-group">
              <label for="category">Category</label>
              <select id="category" name="category" required>
                <option value="" disabled selected>Select…</option>
                <option value="Food">🍔 Food</option>
                <option value="Transport">🚌 Transport</option>
                <option value="Bills">💡 Bills</option>
                <option value="Shopping">🛍️ Shopping</option>
                <option value="Health">💊 Health</option>
                <option value="Entertainment">🎬 Entertainment</option>
                <option value="Others">📦 Others</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label for="date">Date</label>
            <input type="date" id="date" name="date" required />
          </div>

          <button type="submit" class="btn-submit">Add Expense</button>
        </form>
      </section>

      <!-- CATEGORY BREAKDOWN -->
      <section class="card breakdown-card">
        <h2 class="card-title">By Category</h2>
        <ul class="breakdown-list">
          <% categoryBreakdown.forEach((category) => { %>

          <li class="breakdown-item">
            <div class="breakdown-left">
              <span class="cat-emoji"><%=category.emoji%></span>
              <span class="cat-name"><%=category.name%></span>
            </div>
            <div class="breakdown-right">
              <span class="cat-amount">₦<%=category.total.toLocaleString()%></span>
              <div class="cat-bar-track">
                <div class="cat-bar-fill" style="width: <%=category.percent%>%"></div>
              </div>
            </div>
          </li>
          <% }) %>

